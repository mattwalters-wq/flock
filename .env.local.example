# Flock - local development environment
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to git.

# Supabase (Flock project: pzcajxpqljulokvowcev)
NEXT_PUBLIC_SUPABASE_URL=https://pzcajxpqljulokvowcev.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-flock-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-flock-service-role-key-here

# Platform domain
# Subdomains: <slug>.fans-flock.com -> tenant with that slug
NEXT_PUBLIC_APP_DOMAIN=fans-flock.com

# Dev override: which tenant to use on localhost
DEV_TENANT_SLUG=the-stamps

# Resend (email)
RESEND_API_KEY=your-resend-api-key-here

# Vercel API (for auto-provisioning subdomains)
VERCEL_API_TOKEN=your-vercel-api-token-here
VERCEL_PROJECT_ID=your-vercel-project-id-here
