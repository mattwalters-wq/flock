# =============================================================
# Flock — .env.local.example
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================

# -------------------------------------------------------------
# Supabase — Flock project (pzcajxpqljulokvowcev)
# Get these from: supabase.com/dashboard/project/pzcajxpqljulokvowcev/settings/api-keys
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://pzcajxpqljulokvowcev.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-flock-anon-key-here

# Service role key — server-side only, NEVER expose to client
# Get from: supabase.com/dashboard/project/pzcajxpqljulokvowcev/settings/api-keys
SUPABASE_SERVICE_ROLE_KEY=your-flock-service-role-key-here

# -------------------------------------------------------------
# Resend — email sending
# Get from: resend.com/api-keys
# -------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key_here

# -------------------------------------------------------------
# Flock — tenant routing
# The slug of the tenant this deployment serves.
# For local dev, set to 'the-stamps' to develop against Stamps data.
# In production, each deployment sets this to its own tenant slug.
# -------------------------------------------------------------
FLOCK_TENANT_SLUG=the-stamps

# -------------------------------------------------------------
# Next.js
# -------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# -------------------------------------------------------------
# Optional: Vercel-specific (auto-set in Vercel deployments)
# VERCEL_URL is set automatically by Vercel — do not set manually
# -------------------------------------------------------------
# VERCEL_URL=

