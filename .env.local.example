# ─────────────────────────────────────────────────────────────────────────────
# Flock — local development environment
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Flock project: pzcajxpqljulokvowcev) ───────────────────────────
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://pzcajxpqljulokvowcev.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-flock-anon-key-here

# Only needed for server-side admin operations (migrations, seed scripts).
# Do NOT expose this in client-side code.
# SUPABASE_SERVICE_ROLE_KEY=your-flock-service-role-key-here

# ── Platform domain ───────────────────────────────────────────────────────────
# The root domain for subdomain routing.
# Subdomains: <slug>.fans-flock.com → resolves to tenant with that slug.
# Vercel env vars to add: NEXT_PUBLIC_APP_DOMAIN=fans-flock.com
NEXT_PUBLIC_APP_DOMAIN=fans-flock.com

# ── Development overrides ─────────────────────────────────────────────────────
# Which tenant slug to use when running on localhost (no subdomain available).
DEV_TENANT_SLUG=the-stamps

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Added in Task 6+ when transactional email is wired up.
# RESEND_API_KEY=your-resend-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Vercel environment variables required for production deploy:
#
#   NEXT_PUBLIC_SUPABASE_URL     = https://pzcajxpqljulokvowcev.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY = <your Flock anon key>
#   NEXT_PUBLIC_APP_DOMAIN       = fans-flock.com
#   DEV_TENANT_SLUG              = the-stamps  (for preview deployments)
#
# NOTE: stamps-land Supabase (qkpfxcdcmpqmuuaafppw) is READ-ONLY reference.
# Never point Flock env vars at the stamps-land project.
# ─────────────────────────────────────────────────────────────────────────────
